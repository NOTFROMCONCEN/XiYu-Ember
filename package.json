{
  "name": "qiyu-ember-website",
  "version": "1.0.0",
  "description": "栖屿 Ember 轰趴馆官方网站 - 基于 Node.js + Express 构建的高性能个人博客",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js --watch src --ext js,json server.js",
    "debug": "node --inspect server.js",
    "build": "node -e \"const fs=require('fs'); fs.cpSync('public', '.', {recursive:true,force:true}); console.log('Static assets copied to root')\"",
    "test": "echo 'Tests not yet configured' && exit 0",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{js,json}'",
    "format:check": "prettier --check 'src/**/*.{js,json}'",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js"
  },
  "keywords": [
    "website",
    "blog",
    "express",
    "node"
  ],
  "author": "Huameitang",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.5.3"
  }
}
