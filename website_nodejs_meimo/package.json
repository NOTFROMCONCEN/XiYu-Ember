{
  "name": "qiyu-ember-website",
  "version": "1.0.0",
  "description": "栖屿 Ember 轰趴馆官方网站 - 基于 Node.js + Express 构建的高性能个人博客",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js --watch src --ext js,json server.js",
    "debug": "node --inspect server.js",
    "build": "echo 'Build step placeholder - no build required for static site'",
    "test": "echo 'Tests not yet configured' && exit 0",
    "lint": "echo 'Linting not yet configured'",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js"
  },
  "keywords": [
    "website",
    "blog",
    "express",
    "node"
  ],
  "author": "Huameitang",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^7.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
